{
  "output_dir": "outputs",
  "wechat_mp": {
    "label": "微信公众号",
    "url_patterns": [
      "mp.weixin.qq.com/s/"
    ]
  },
  "zhihu_zhuanlan": {
    "label": "知乎专栏",
    "url_patterns": [
      "zhuanlan.zhihu.com/p/"
    ]
  },
  "xiaoheihe": {
    "label": "小黑盒",
    "url_patterns": [
      "xiaoheihe.cn/bbs/post_share"
    ]
  },
  "siyuan": {
    "api_base": "http://127.0.0.1:6806",
    "default_parent_id": "your-target-notebook-or-parent-document-id",
    "token": "your-siyuan-token-here"
  },
  "ai": {
    "provider": "anthropic",
    "max_attempts": 2,
    "rewrite_prompt_path": "prompts/rewrite_article.md",
    "review_metadata_prompt_path": "prompts/review_metadata.md",
    "verify_prompt_path": "prompts/pre_upload_review.md"
  },
  "ai_providers": {
    "openai": {
      "model": "your-openai-model",
      "api_base": "https://api.openai.com/v1",
      "api_key": "your-openai-api-key-here",
      "max_output_tokens": 12000,
      "temperature": 0.2
    },
    "anthropic": {
      "model": "your-anthropic-model",
      "api_base": "https://api.anthropic.com",
      "api_key": "your-anthropic-api-key-here",
      "max_output_tokens": 12000,
      "temperature": 0.2
    }
  },
  "smtp": {
    "host": "smtp.example.com",
    "port": 587,
    "user": "sender@example.com",
    "password": "your-smtp-password",
    "sender_name": "你的称呼",
    "allowed_recipients": ["friend@example.com"]
  }
}
